<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ReceiptPrinterEmulator.ViewModels"
        mc:Ignorable="d" d:DesignWidth="730" d:DesignHeight="800"
        x:Class="ReceiptPrinterEmulator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ESC/POS Receipt Printer Emulator"
        Width="730" Height="800" MinWidth="730"
        Background="#262626">

    <DockPanel>
        <Border DockPanel.Dock="Left" Background="#3b3b3b">
            <StackPanel Margin="15 10" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{Binding StatusBrush}"
                           FontWeight="Bold" Margin="0 0 0 10"/>
                <Button Command="{Binding ResetCommand}" Padding="5 3" Margin="0 0 0 10"
                        HorizontalAlignment="Stretch" Content="Reset"/>
                <Button Command="{Binding TestPrintCommand}" Padding="5 3" Margin="0 0 0 10"
                        HorizontalAlignment="Stretch" Content="Test print"/>
                <Button Command="{Binding HexDumpCommand}" Padding="5 3" Margin="0 0 0 10"
                        HorizontalAlignment="Stretch" Content="Hex Dump Test Ticket"/>
            </StackPanel>
        </Border>

        <ScrollViewer Name="MainScrollView"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Visible">
            <ItemsControl ItemsSource="{Binding Receipts}" Margin="0 10 0 0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ReceiptViewModel">
                        <Image Source="{Binding Image}"
                               Stretch="None"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 10"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
