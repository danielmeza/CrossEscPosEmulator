<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReceiptPrinterEmulator.ViewModels"
        x:Class="ReceiptPrinterEmulator.Views.MonitorWindow"
        x:DataType="vm:MonitorWindowViewModel"
        Icon="/Assets/Icon/icon-256.png"
        Title="ESC/POS Monitor (client)"
        Width="520" Height="620" MinWidth="460"
        Background="#262626">

    <Window.Styles>
        <Style Selector="Button.action">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Styles>

    <DockPanel Margin="14">
        <!-- Connection -->
        <Border DockPanel.Dock="Top" Background="#3b3b3b" CornerRadius="6" Padding="12" Margin="0 0 0 10">
            <StackPanel>
                <TextBlock Text="Connect to emulator / printer" Foreground="White" FontWeight="Bold" Margin="0 0 0 8"/>

                <ComboBox HorizontalAlignment="Stretch" Margin="0 0 0 6"
                          ItemsSource="{Binding Transports}" SelectedItem="{Binding Transport}"/>

                <!-- TCP fields -->
                <Grid IsVisible="{Binding IsTcp}" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0" Text="{Binding Host}" PlaceholderText="host"/>
                    <TextBox Grid.Column="1" Width="80" Text="{Binding Port}" PlaceholderText="port"/>
                </Grid>

                <!-- Serial fields -->
                <Grid IsVisible="{Binding IsSerial}" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SerialPortName}"/>
                    <Button Grid.Column="1" Content="⟳" Command="{Binding RefreshPortsCommand}" ToolTip.Tip="Refresh ports"/>
                    <TextBox Grid.Column="2" Width="80" Text="{Binding SerialBaud}" PlaceholderText="baud"/>
                </Grid>

                <!-- USB fields -->
                <StackPanel IsVisible="{Binding IsUsb}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding AvailableUsbDevices}" SelectedItem="{Binding SelectedUsbDevice}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1" Content="⟳" Command="{Binding RefreshUsbCommand}" ToolTip.Tip="Refresh USB devices"/>
                    </Grid>
                    <TextBlock Text="Direct USB (libusb) — send-only, no status. Needs libusb installed."
                               Classes="label" TextWrapping="Wrap" Margin="0 4 0 0"/>
                </StackPanel>

                <Button Content="{Binding ConnectButtonText}" Command="{Binding ToggleConnectCommand}"
                        HorizontalAlignment="Stretch" Margin="0 8 0 0"/>
            </StackPanel>
        </Border>

        <!-- Reported status -->
        <Border DockPanel.Dock="Top" Background="#1f1f1f" CornerRadius="6" Padding="12" Margin="0 0 0 10">
            <StackPanel>
                <TextBlock Text="Printer status (from emulator)" Classes="label" Margin="0 0 0 6"/>
                <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="Bold" Margin="0 0 0 8"/>
                <ItemsControl ItemsSource="{Binding Indicators}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:StatusIndicator">
                            <Grid ColumnDefinitions="Auto,110,*" Margin="0 3">
                                <Ellipse Grid.Column="0" Width="12" Height="12" Fill="{Binding Color}"
                                         VerticalAlignment="Center" Margin="0 0 8 0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="#BBBBBB" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Value}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Send actions -->
        <Border DockPanel.Dock="Top" Margin="0 0 0 10">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <StackPanel Grid.Column="0">
                    <Button Classes="action" Content="Print sample receipt" Command="{Binding SendSampleCommand}"/>
                    <Button Classes="action" Content="Print all barcodes" Command="{Binding SendBarcodesCommand}"/>
                    <Button Classes="action" Content="Print QR / PDF417 / Aztec" Command="{Binding SendQrCommand}"/>
                    <Button Classes="action" Content="Send full feature test" Command="{Binding SendFullTestCommand}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <Button Classes="action" Content="Open cash drawer" Command="{Binding OpenDrawerCommand}"/>
                    <Button Classes="action" Content="Buzzer" Command="{Binding BeepCommand}"/>
                    <Button Classes="action" Content="Cut" Command="{Binding CutCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log -->
        <Border Background="#1f1f1f" CornerRadius="6" Padding="8">
            <DockPanel>
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="2 0 0 6">
                    <TextBlock Grid.Column="0" Text="Activity" Classes="label" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Copy" Padding="10 2" FontSize="11"
                            Click="OnCopyLog" ToolTip.Tip="Copy the activity log to the clipboard"/>
                </Grid>
                <ListBox ItemsSource="{Binding Log}" Background="Transparent" FontFamily="monospace" FontSize="12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <SelectableTextBlock Text="{Binding}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
