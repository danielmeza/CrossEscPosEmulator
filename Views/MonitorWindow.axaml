<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReceiptPrinterEmulator.ViewModels"
        x:Class="ReceiptPrinterEmulator.Views.MonitorWindow"
        x:DataType="vm:MonitorWindowViewModel"
        Icon="/Assets/Icon/icon-256.png"
        Title="ESC/POS Monitor (client)"
        Width="520" Height="620" MinWidth="460"
        Background="#262626">

    <Window.Styles>
        <Style Selector="Button.action">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Styles>

    <DockPanel Margin="14">
        <!-- Connection -->
        <Border DockPanel.Dock="Top" Background="#3b3b3b" CornerRadius="6" Padding="12" Margin="0 0 0 10">
            <StackPanel>
                <TextBlock Text="Connect to emulator" Foreground="White" FontWeight="Bold" Margin="0 0 0 8"/>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0" Text="{Binding Host}" PlaceholderText="host"/>
                    <TextBox Grid.Column="1" Width="70" Text="{Binding Port}" PlaceholderText="port"/>
                    <Button Grid.Column="2" Content="{Binding ConnectButtonText}" Command="{Binding ToggleConnectCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Reported status -->
        <Border DockPanel.Dock="Top" Background="#1f1f1f" CornerRadius="6" Padding="12" Margin="0 0 0 10">
            <StackPanel>
                <TextBlock Text="Printer status (from emulator)" Classes="label" Margin="0 0 0 6"/>
                <TextBlock Text="{Binding StatusText}" Foreground="#3CE07A" FontFamily="monospace"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Send actions -->
        <Border DockPanel.Dock="Top" Margin="0 0 0 10">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <StackPanel Grid.Column="0">
                    <Button Classes="action" Content="Print sample receipt" Command="{Binding SendSampleCommand}"/>
                    <Button Classes="action" Content="Print all barcodes" Command="{Binding SendBarcodesCommand}"/>
                    <Button Classes="action" Content="Print QR / PDF417 / Aztec" Command="{Binding SendQrCommand}"/>
                    <Button Classes="action" Content="Send full feature test" Command="{Binding SendFullTestCommand}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <Button Classes="action" Content="Open cash drawer" Command="{Binding OpenDrawerCommand}"/>
                    <Button Classes="action" Content="Buzzer" Command="{Binding BeepCommand}"/>
                    <Button Classes="action" Content="Cut" Command="{Binding CutCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log -->
        <Border Background="#1f1f1f" CornerRadius="6" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Activity" Classes="label" Margin="2 0 0 6"/>
                <ListBox ItemsSource="{Binding Log}" Background="Transparent" FontFamily="monospace" FontSize="12"/>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
