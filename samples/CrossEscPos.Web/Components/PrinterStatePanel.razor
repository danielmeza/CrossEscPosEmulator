@* Drives the simulated PrinterState — the Razor analogue of the Avalonia PrinterStatePanel. Two-way
   bound, so toggling feeds the status commands (DLE EOT, GS r) and Automatic Status Back (GS a). *@

<div class="card">
    <h2>Printer state</h2>

    <div class="state-row">
        <span class="lbl">@(State.Online ? "Online" : "Offline")</span>
        <label class="switch"><input type="checkbox" @bind="Online" /><span class="slider"></span></label>
    </div>

    <div class="state-row">
        <span class="lbl">@(State.CoverOpen ? "Cover open" : "Cover closed")</span>
        <label class="switch"><input type="checkbox" @bind="CoverOpen" /><span class="slider"></span></label>
    </div>

    <label class="field">Paper</label>
    <select @bind="Paper">
        @foreach (var level in Enum.GetValues<PaperLevel>())
        {
            <option value="@level">@level</option>
        }
    </select>

    <label class="field">Error</label>
    <select @bind="Error">
        @foreach (var err in Enum.GetValues<PrinterErrorState>())
        {
            <option value="@err">@err</option>
        }
    </select>

    <h2 style="margin-top:16px;">Cash drawer</h2>
    <div class="state-row">
        <span class="lbl">@(State.DrawerOpen ? "Drawer open" : "Drawer closed")</span>
        <label class="switch"><input type="checkbox" @bind="DrawerOpen" /><span class="slider"></span></label>
    </div>

    <div class="state-row">
        <span class="lbl">@(State.FeedButtonPressed ? "Feed button down" : "Feed button up")</span>
        <label class="switch"><input type="checkbox" @bind="FeedButtonPressed" /><span class="slider"></span></label>
    </div>

    <p class="note">
        These drive the status commands (DLE EOT, GS r) and Automatic Status Back (GS a) reported to a
        connected host. They take effect once a live transport (Web Serial / WebUSB) is attached.
    </p>
</div>

@code {
    [Parameter, EditorRequired] public PrinterState State { get; set; } = default!;

    // Wrappers so @bind writes straight through to the observable state (which raises its Changed event).
    private bool Online { get => State.Online; set => State.Online = value; }
    private bool CoverOpen { get => State.CoverOpen; set => State.CoverOpen = value; }
    private bool DrawerOpen { get => State.DrawerOpen; set => State.DrawerOpen = value; }
    private bool FeedButtonPressed { get => State.FeedButtonPressed; set => State.FeedButtonPressed = value; }
    private PaperLevel Paper { get => State.Paper; set => State.Paper = value; }
    private PrinterErrorState Error { get => State.Error; set => State.Error = value; }
}
