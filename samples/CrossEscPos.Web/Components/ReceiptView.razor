@* Displays one rendered receipt as a PNG with a download link — the Razor analogue of the Avalonia
   ReceiptView. The image bytes come from the active render backend via the EmulatorHost. *@

<div class="receipt">
    <div class="receipt-head">
        <span class="receipt-title">@Title</span>
        <a class="btn ghost" download="@FileName" href="@_dataUri">Download PNG</a>
    </div>
    <div class="receipt-paper">
        <img src="@_dataUri" alt="@Title" />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public EmulatorHost Host { get; set; } = default!;
    [Parameter, EditorRequired] public Receipt Receipt { get; set; } = default!;
    [Parameter] public int Index { get; set; }

    private string _dataUri = "";

    private string Title => $"Cut #{Index}";
    private string FileName => $"receipt_{Index:D3}.png";

    // Re-render the PNG only when the inputs change, not on every parent StateHasChanged.
    protected override void OnParametersSet()
        => _dataUri = $"data:image/png;base64,{Host.RenderPngBase64(Receipt)}";
}
