@page "/"
@inject EmulatorHost Host
@inject HttpClient Http
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>CrossEscPos Web — ESC/POS emulator</PageTitle>

@* Column 1 — engine + input *@
<section class="card">
    <h2>Render engine</h2>
    <div class="engine-options">
        @foreach (var b in Host.Backends)
        {
            <label class="engine-option @(b.Id == Host.Backend.Id ? "active" : "")">
                <input type="radio" name="engine"
                       checked="@(b.Id == Host.Backend.Id)"
                       @onchange="@(() => SwitchEngineAsync(b.Id))" />
                <span>
                    <span class="name">@b.Name</span>
                    <span class="blurb">@b.Blurb</span>
                </span>
            </label>
        }
    </div>

    <h2 style="margin-top:18px;">ESC/POS input</h2>
    <label class="field">Paste text or raw bytes (decoded as Latin-1)</label>
    <textarea @bind="_text" @bind:event="oninput" spellcheck="false"></textarea>

    <label class="field">…or upload an ESC/POS file</label>
    <InputFile OnChange="OnFileAsync" />

    <div class="btn-row">
        <button class="btn primary" @onclick="RenderText">Render</button>
        <button class="btn" @onclick="LoadSampleAsync">Load sample</button>
        <button class="btn ghost" @onclick="ClearAll">Clear</button>
    </div>
</section>

@* Column 2 — rendered receipts *@
<section class="card">
    <h2>Receipts (@Host.Receipts.Count)</h2>
    @if (Host.Receipts.Count == 0)
    {
        <div class="empty-hint">No printable output yet. Render some ESC/POS to see the receipt.</div>
    }
    else
    {
        <div class="receipts">
            @{ var i = 1; }
            @foreach (var receipt in Host.Receipts)
            {
                <ReceiptView Host="Host" Receipt="receipt" Index="i" @key="receipt.Guid" />
                i++;
            }
        </div>
    }
</section>

@* Column 3 — printer state *@
<PrinterStatePanel State="Host.State" />

@code {
    private string _text = "*** CrossEscPos Web ***\nManaged ImageSharp backend\n\nItem            $ 4.50\nTax             $ 0.36\nTOTAL           $ 4.86\n\nThank you!\n";

    protected override async Task OnInitializedAsync()
    {
        Host.Changed += OnHostChanged;

        // Restore the previously selected engine, if any.
        var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "crossescpos.engine");
        if (!string.IsNullOrEmpty(saved) && saved != Host.Backend.Id)
            Host.UseBackend(saved);

        // Render the prefilled sample so the app shows a receipt on first load.
        RenderText();
    }

    private void OnHostChanged() => InvokeAsync(StateHasChanged);

    private async Task SwitchEngineAsync(string id)
    {
        Host.UseBackend(id);
        await JS.InvokeVoidAsync("localStorage.setItem", "crossescpos.engine", id);
    }

    private void RenderText()
        => Host.Render(System.Text.Encoding.Latin1.GetBytes(_text));

    private async Task OnFileAsync(InputFileChangeEventArgs e)
    {
        using var ms = new MemoryStream();
        await e.File.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024).CopyToAsync(ms);
        Host.Render(ms.ToArray());
    }

    private async Task LoadSampleAsync()
    {
        var bytes = await Http.GetByteArrayAsync("sample.escpos");
        Host.Render(bytes);
    }

    private void ClearAll()
    {
        _text = string.Empty;
        Host.Clear();
    }

    public void Dispose() => Host.Changed -= OnHostChanged;
}
