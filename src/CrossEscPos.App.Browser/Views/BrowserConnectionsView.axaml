<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrossEscPos.App.Browser.ViewModels"
             x:Class="CrossEscPos.App.Browser.Views.BrowserConnectionsView"
             x:DataType="vm:BrowserConnectionsViewModel">
    <StackPanel>
        <StackPanel.Styles>
            <Style Selector="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0 4 0 0"/>
            </Style>
            <Style Selector="TextBlock.section">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="0 14 0 4"/>
            </Style>
            <Style Selector="TextBlock.status">
                <Setter Property="Foreground" Value="#9aa0a8"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="0 2 0 0"/>
            </Style>
        </StackPanel.Styles>

        <TextBlock Classes="section" Text="Live connections"/>

        <Button Command="{Binding ToggleSerialCommand}" Content="{Binding SerialButtonText, StringFormat='{}{0} Web Serial'}"
                IsEnabled="{Binding SerialSupported}"/>
        <TextBlock Classes="status" Text="{Binding SerialStatus}"/>

        <Button Command="{Binding ToggleUsbCommand}" Content="{Binding UsbButtonText, StringFormat='{}{0} WebUSB'}"
                IsEnabled="{Binding UsbSupported}"/>
        <TextBlock Classes="status" Text="{Binding UsbStatus}"/>

        <TextBlock Classes="section" Text="WebSocket (TCP proxy)"/>
        <TextBox Text="{Binding WsUrl, Mode=TwoWay}" Watermark="ws://localhost:5000/ws"/>
        <Button Command="{Binding ToggleWsCommand}" Content="{Binding WsButtonText, StringFormat='{}{0} WebSocket'}"/>
        <TextBlock Classes="status" Text="{Binding WsStatus}"/>

        <TextBlock Classes="status" TextWrapping="Wrap" Margin="0 8 0 0"
                   Text="Serial/USB need Chromium + a user gesture. WebSocket bridges TCP:9100 via CrossEscPos.WsProxy."/>
    </StackPanel>
</UserControl>
