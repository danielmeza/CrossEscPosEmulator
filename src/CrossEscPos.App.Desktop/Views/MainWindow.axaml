<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CrossEscPos.App.Desktop.ViewModels"
        xmlns:controls="using:CrossEscPos.Controls"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="800"
        x:Class="CrossEscPos.App.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icon/icon-256.png"
        Title="ESC/POS Receipt Printer Emulator"
        Width="1120" Height="820" MinWidth="1040"
        Background="#262626">

    <Grid>
    <DockPanel>
        <Border DockPanel.Dock="Left" Background="#3b3b3b" Width="250">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <StackPanel.Styles>
                        <Style Selector="Button">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0 4 0 0"/>
                        </Style>
                        <Style Selector="TextBlock.section">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Margin" Value="0 14 0 4"/>
                        </Style>
                        <Style Selector="TextBlock.label">
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Margin" Value="0 6 0 2"/>
                        </Style>
                        <Style Selector="ComboBox">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        </Style>
                        <Style Selector="TextBox">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        </Style>
                    </StackPanel.Styles>

                    <!-- TCP -->
                    <TextBlock Classes="section" Text="TCP/IP" Margin="0 0 0 4"/>
                    <TextBlock Classes="label" Text="Listen address"/>
                    <ComboBox ItemsSource="{Binding AvailableAddresses}"
                              SelectedItem="{Binding SelectedAddress}"/>
                    <TextBlock Classes="label" Text="Port"/>
                    <TextBox Text="{Binding TcpPortText}"/>
                    <Button Command="{Binding ToggleTcpCommand}" Content="{Binding TcpButtonText}"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"
                               TextWrapping="Wrap" FontSize="11" Margin="0 4 0 0"/>

                    <!-- Serial -->
                    <TextBlock Classes="section" Text="Serial"/>
                    <TextBlock Classes="label" Text="Port"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding SelectedSerialPort}"/>
                        <Button Grid.Column="1" Command="{Binding RefreshSerialPortsCommand}"
                                Content="⟳" Margin="4 0 0 0" ToolTip.Tip="Refresh ports"/>
                    </Grid>
                    <TextBlock Classes="label" Text="Baud rate"/>
                    <TextBox Text="{Binding BaudText}"/>
                    <Button Command="{Binding ToggleSerialCommand}" Content="{Binding SerialButtonText}"/>
                    <TextBlock Text="{Binding SerialStatusText}" Foreground="#CCCCCC"
                               TextWrapping="Wrap" FontSize="11" Margin="0 4 0 0"/>

                    <!-- Actions -->
                    <TextBlock Classes="section" Text="Actions"/>
                    <Button Command="{Binding ResetCommand}" Content="Reset"/>
                    <Button Command="{Binding HexDumpCommand}" Content="Hex Dump Test Ticket"/>
                    <Button Command="{Binding OpenMonitorCommand}" Content="Open monitor…"/>

                    <!-- Export -->
                    <TextBlock Classes="section" Text="Export"/>
                    <Button Command="{Binding ExportAllCommand}" Content="Export all (single image)…"/>
                    <Button Command="{Binding ExportEachCommand}" Content="Export each cut (folder)…"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Reusable printer-state panel from the Controls package. -->
        <Border DockPanel.Dock="Right" Background="#3b3b3b" Width="220">
            <controls:PrinterStatePanel State="{Binding State}"/>
        </Border>

        <!-- Reusable receipt viewer from the Controls package. -->
        <controls:ReceiptView Name="Receipts" Receipts="{Binding Receipts}"/>
    </DockPanel>

        <!-- Transient toast for buzzer / cash-drawer events -->
        <Border IsVisible="{Binding ToastVisible}"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0 24 0 0" Padding="20 12"
                Background="#E6202020" CornerRadius="8"
                BoxShadow="0 4 16 0 #80000000" IsHitTestVisible="False">
            <TextBlock Text="{Binding ToastMessage}" Foreground="White"
                       FontSize="16" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
