<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrossEscPos.App.Monitor"
        xmlns:views="using:CrossEscPos.App.Views"
        x:Class="CrossEscPos.App.Desktop.Views.MonitorWindow"
        x:DataType="vm:MonitorViewModel"
        Icon="/Assets/Icon/icon-256.png"
        Title="ESC/POS Monitor (client)"
        Width="520" Height="720" MinWidth="460"
        Background="#262626">

    <!-- Hosts the shared MonitorView; DataContext (a MonitorViewModel) is set by ShowMonitorWindow. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <views:MonitorView/>
    </ScrollViewer>
</Window>
